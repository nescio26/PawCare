import { useNavigate, useParams } from "react-router-dom";
import { usePet } from "../../hooks/usePets.js";
import { useVisitsByPet } from "../../hooks/useVisits.js";
import { useRecordsByPet } from "../../hooks/useRecords.js";
import PageHeader from "../../components/shared/PageHeader.jsx";
import LoadingSpinner from "../../components/shared/LoadingSpinner.jsx";
import EmptyState from "../../components/shared/EmptyState.jsx";
import Breadcrumbs from "../../components/shared/Breadcrumbs.jsx";
import { Button } from "../../components/ui/button.jsx";
import {
  Card,
  CardContent,
  CardHeader,
  CardTitle,
} from "../../components/ui/card.jsx";
import {
  Tabs,
  TabsContent,
  TabsList,
  TabsTrigger,
} from "../../components/ui/tabs.jsx";
import { Badge } from "../../components/ui/badge.jsx";
import {
  Edit,
  Plus,
  PawPrint,
  Calendar,
  Weight,
  Fingerprint,
  ChevronRight,
} from "lucide-react";
import { useAuthStore } from "../../store/authStore.js";
import { formatDate } from "../../utils/formatDate.js";
import { cn } from "../../utils/cn.js";

const statusColors = {
  waiting:
    "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400",
  "in-progress":
    "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
  done: "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400",
  cancelled: "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400",
};

export default function PetDetailPage() {
  const { id } = useParams();
  const navigate = useNavigate();
  const { user } = useAuthStore();
  const { data: petData, isLoading } = usePet(id);
  const { data: visitsData } = useVisitsByPet(id);
  const { data: recordsData } = useRecordsByPet(id);

  if (isLoading) return <LoadingSpinner />;

  const pet = petData?.data;
  const visits = visitsData?.data || [];
  const records = recordsData?.data || [];

  if (!pet) return <EmptyState title="Pet not found" />;

  return (
    <div className="space-y-6 max-w-4xl mx-auto">
      <Breadcrumbs
        items={[
          { label: "Owners", href: "/owners" },
          { label: pet.owner?.name, href: `/owners/${pet.owner?._id}` },
          { label: pet.name },
        ]}
      />

      <PageHeader
        title={pet.name}
        description={pet.breed || pet.species}
        action={
          user?.role !== "vet" && (
            <Button
              variant="outline"
              size="sm"
              onClick={() => navigate(`/pets/${id}/edit`)}
            >
              <Edit className="w-4 h-4 mr-2" />
              Edit Profile
            </Button>
          )
        }
      />

      <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
        {/* Left Column: Pet Stats */}
        <Card className="md:col-span-2">
          <CardHeader className="pb-2">
            <CardTitle className="text-sm font-bold uppercase tracking-wider text-muted-foreground">
              Vital Statistics
            </CardTitle>
          </CardHeader>
          <CardContent>
            <div className="grid grid-cols-2 sm:grid-cols-3 gap-6">
              <div className="space-y-1">
                <p className="text-xs text-muted-foreground flex items-center gap-1">
                  <PawPrint className="w-3 h-3" /> Species
                </p>
                <p className="text-sm font-semibold capitalize">
                  {pet.species}
                </p>
              </div>
              <div className="space-y-1">
                <p className="text-xs text-muted-foreground flex items-center gap-1">
                  <Weight className="w-3 h-3" /> Weight
                </p>
                <p className="text-sm font-semibold">
                  {pet.weight ? `${pet.weight} kg` : "N/A"}
                </p>
              </div>
              <div className="space-y-1">
                <p className="text-xs text-muted-foreground flex items-center gap-1">
                  <Calendar className="w-3 h-3" /> Age
                </p>
                <p className="text-sm font-semibold">
                  {pet.dateOfBirth ? formatDate(pet.dateOfBirth) : "Unknown"}
                </p>
              </div>
              <div className="space-y-1">
                <p className="text-xs text-muted-foreground flex items-center gap-1">
                  <Fingerprint className="w-3 h-3" /> Microchip
                </p>
                <p className="text-sm font-mono text-[11px] truncate">
                  {pet.microchipNo || "Not chipped"}
                </p>
              </div>
            </div>
          </CardContent>
        </Card>

        {/* Right Column: Owner Profile */}
        <Card className="bg-primary/5 border-primary/10">
          <CardHeader className="pb-2">
            <CardTitle className="text-sm font-bold uppercase tracking-wider text-muted-foreground">
              Responsible Owner
            </CardTitle>
          </CardHeader>
          <CardContent>
            <div
              className="flex items-center gap-3 p-2 rounded-lg hover:bg-background cursor-pointer transition-colors"
              onClick={() => navigate(`/owners/${pet.owner?._id}`)}
            >
              <div className="w-10 h-10 rounded-full bg-primary text-primary-foreground flex items-center justify-center font-bold">
                {pet.owner?.name?.charAt(0).toUpperCase()}
              </div>
              <div className="flex-1 min-w-0">
                <p className="text-sm font-bold truncate">{pet.owner?.name}</p>
                <p className="text-xs text-muted-foreground">
                  {pet.owner?.phone}
                </p>
              </div>
              <ChevronRight className="w-4 h-4 text-muted-foreground" />
            </div>
          </CardContent>
        </Card>
      </div>

      {/* Bottom Section: Tabs for History and Records */}
      <Tabs defaultValue="visits" className="w-full">
        <TabsList className="grid w-full grid-cols-2 max-w-[400px]">
          <TabsTrigger value="visits" className="font-bold">
            Visits
          </TabsTrigger>
          <TabsTrigger value="records" className="font-bold">
            Medical Records
          </TabsTrigger>
        </TabsList>

        <TabsContent value="visits" className="mt-4">
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0">
              <CardTitle className="text-base">Visit History</CardTitle>
              {user?.role !== "vet" && (
                <Button
                  size="sm"
                  onClick={() =>
                    navigate(
                      `/visits/new?petId=${id}&ownerId=${pet.owner?._id}`,
                    )
                  }
                >
                  <Plus className="w-4 h-4 mr-2" /> New Visit
                </Button>
              )}
            </CardHeader>
            <CardContent>
              {visits.length === 0 ? (
                <EmptyState title="No recorded visits" compact />
              ) : (
                <div className="space-y-3">
                  {visits.map((visit) => (
                    <div
                      key={visit._id}
                      className="flex items-center gap-4 p-4 rounded-xl border bg-card/50"
                    >
                      <div className="w-8 h-8 rounded-lg bg-muted flex items-center justify-center font-mono text-xs">
                        #{visit.queueNo}
                      </div>
                      <div className="flex-1">
                        <p className="text-sm font-bold">
                          {visit.reason || "General Checkup"}
                        </p>
                        <p className="text-xs text-muted-foreground">
                          {formatDate(visit.visitDate)}{" "}
                          {visit.vet && `• Dr. ${visit.vet.name}`}
                        </p>
                      </div>
                      <Badge
                        className={cn(
                          "capitalize border-none",
                          statusColors[visit.status],
                        )}
                      >
                        {visit.status}
                      </Badge>
                    </div>
                  ))}
                </div>
              )}
            </CardContent>
          </Card>
        </TabsContent>

        <TabsContent value="records" className="mt-4">
          <Card>
            <CardHeader className="flex flex-row items-center justify-between space-y-0">
              <CardTitle className="text-base">Clinical Records</CardTitle>
              {user?.role !== "staff" && (
                <Button
                  size="sm"
                  onClick={() => navigate(`/records/new?petId=${id}`)}
                >
                  <Plus className="w-4 h-4 mr-2" /> Add Record
                </Button>
              )}
            </CardHeader>
            <CardContent>
              {records.length === 0 ? (
                <EmptyState title="No medical records" compact />
              ) : (
                <div className="space-y-4">
                  {records.map((record) => (
                    <div
                      key={record._id}
                      className="p-4 rounded-xl border-l-4 border-l-primary bg-muted/20 space-y-2"
                    >
                      <div className="flex justify-between items-start">
                        <p className="text-sm font-bold text-primary">
                          {record.diagnosis || "Observation"}
                        </p>
                        <span className="text-[10px] font-medium text-muted-foreground uppercase">
                          {formatDate(record.createdAt)}
                        </span>
                      </div>
                      <p className="text-xs leading-relaxed text-muted-foreground">
                        <span className="font-bold text-foreground">
                          Symptoms:
                        </span>{" "}
                        {record.symptoms || "None reported"}
                      </p>
                      {record.vet && (
                        <div className="pt-2 border-t mt-2 flex items-center gap-2">
                          <div className="w-4 h-4 rounded-full bg-primary/20" />
                          <p className="text-[10px] font-medium">
                            Attending Vet: {record.vet.name}
                          </p>
                        </div>
                      )}
                    </div>
                  ))}
                </div>
              )}
            </CardContent>
          </Card>
        </TabsContent>
      </Tabs>
    </div>
  );
}
